<resources>
    <!-- Base application theme -->
    <style name="Theme.BudgetBuddy" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand colors -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary accent -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Error color -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Global font (Calibri) -->
        <item name="android:fontFamily">@font/calibri_font</item>
        <item name="fontFamily">@font/calibri_font</item>

        <!-- Rounded buttons (pill shape) -->
        <item name="shapeAppearanceSmallComponent">@style/RoundedButton</item>
        <item name="shapeAppearanceMediumComponent">@style/RoundedButton</item>
        <item name="shapeAppearanceLargeComponent">@style/RoundedButton</item>

        <!-- Watermark background applied to all windows -->
        <item name="android:windowBackground">@drawable/watermark_background</item>
    </style>

    <!-- Rounded corner style for material buttons -->
    <style name="RoundedButton" parent="ShapeAppearance.MaterialComponents">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
</resources>